
""".strip()


def main() -> None:
    payload = json.loads(gzip.decompress(base64.b64decode(SNAPSHOT_B64)).decode("utf-8"))
    for rel_path, text in payload.items():
        path = Path(rel_path)
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(text, encoding="utf-8")
    print(f"restored {len(payload)} processed snapshot files")


if __name__ == "__main__":
    main()
